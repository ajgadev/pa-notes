---
import AppLayout from '../../../layouts/AppLayout.astro';
import NotaForm from '../../../components/NotaForm';
import SignatureStatus from '../../../components/SignatureStatus';
import { db } from '../../../lib/db';
import { notas, notaItems, profiles, config } from '../../../lib/schema';
import { eq } from 'drizzle-orm';
import { formatNotaNumero } from '../../../lib/format';
import { hasAnySignature } from '../../../lib/signatures';

const user = Astro.locals.user;
const id = parseInt(Astro.params.id!);

const notaPrefix = db.select().from(config).where(eq(config.key, 'nota_prefix')).get()?.value ?? 'NS';
const nota = db.select().from(notas).where(eq(notas.id, id)).get();
if (!nota) {
  return Astro.redirect('/notas');
}

const items = db.select().from(notaItems).where(eq(notaItems.notaId, id)).all();
const profile = db.select().from(profiles).where(eq(profiles.userId, user.userId)).get();

const userProfile = {
  nombre: profile?.nombre ?? '',
  apellido: profile?.apellido ?? '',
  ci: profile?.ci ?? '',
};

const hasSigs = hasAnySignature(id);
const userCi = profile?.ci ?? '';
const savedSignature = profile?.savedSignature ?? null;

// Parse tipoSalida for "Otros: ..." case
let tipoSalida = nota.tipoSalida;
let tipoSalidaOtro = '';
if (tipoSalida.startsWith('Otros:')) {
  tipoSalidaOtro = tipoSalida.replace('Otros: ', '').trim();
  tipoSalida = 'Otros';
}

const initialData = {
  departamento: nota.departamento ?? '',
  fecha: nota.fecha ?? '',
  empresa: nota.empresa,
  base: nota.base,
  pozo: nota.pozo ?? '',
  taladro: nota.taladro ?? '',
  tipoSalida,
  tipoSalidaOtro,
  solicitante: nota.solicitante,
  destino: nota.destino,
  vPlaca: nota.vPlaca ?? '',
  vMarca: nota.vMarca ?? '',
  vModelo: nota.vModelo ?? '',
  cNombre: nota.cNombre ?? '',
  cCi: nota.cCi ?? '',
  gNombre: nota.gNombre ?? '',
  gCi: nota.gCi ?? '',
  sNombre: nota.sNombre ?? '',
  sCi: nota.sCi ?? '',
  elabNombre: nota.elabNombre ?? '',
  elabCi: nota.elabCi ?? '',
  aproNombre: nota.aproNombre ?? '',
  aproCi: nota.aproCi ?? '',
  items: items.map((it) => ({
    noParte: it.noParte ?? '',
    unidad: it.unidad,
    cantidad: it.cantidad,
    descripcion: it.descripcion,
    noSerial: it.noSerial ?? '',
  })),
};
---

<AppLayout title={`Editar Nota ${formatNotaNumero(nota.numero, notaPrefix)}`}>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Editar Nota {formatNotaNumero(nota.numero, notaPrefix)}</h1>
    <p class="text-sm text-gray-500">FO-SF-001 — Autorización de Salida de Materiales y/o Equipos</p>
  </div>

  {hasSigs ? (
    <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-sm text-amber-800 font-medium">Esta nota tiene firmas registradas y no puede ser editada.</p>
      <p class="text-xs text-amber-600 mt-1">Para modificarla, anule esta nota y cree una nueva.</p>
    </div>
  ) : (
    <NotaForm client:load userProfile={userProfile} initialData={initialData} notaId={id} isAdmin={user.role === 'admin'} />
  )}

  <div class="mt-6">
    <SignatureStatus client:load notaId={id} userCi={userCi} savedSignature={savedSignature} />
  </div>
</AppLayout>
