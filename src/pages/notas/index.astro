---
import AppLayout from '../../layouts/AppLayout.astro';
import NotasList from '../../components/NotasList';
import { db } from '../../lib/db';
import { config } from '../../lib/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
const notaPrefix = db.select().from(config).where(eq(config.key, 'nota_prefix')).get()?.value ?? 'NS';
---

<AppLayout title="Registro de Notas">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Registro de Notas</h1>
    <p class="text-sm text-gray-500">Autorización de Salida de Materiales y/o Equipos</p>
  </div>

  <NotasList client:load isAdmin={user.role === 'admin'} username={user.username} notaPrefix={notaPrefix} />
</AppLayout>
