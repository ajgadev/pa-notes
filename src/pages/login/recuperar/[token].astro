---
import Layout from '../../../layouts/Layout.astro';
const { token } = Astro.params;
---

<Layout title="Nueva Contraseña">
  <div class="flex min-h-screen items-center justify-center bg-pa-dark">
    <div class="w-full max-w-md rounded-xl bg-white p-8 shadow-xl">
      <div class="mb-6 text-center">
        <h1 class="text-2xl font-bold">
          <span class="text-black">Petro</span><span class="text-pa-orange">Alianza</span>
        </h1>
        <p class="mt-2 text-sm text-gray-500">Establecer Nueva Contraseña</p>
      </div>

      <form id="resetForm" class="space-y-4">
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Nueva contraseña</label>
          <input type="password" id="newPassword" required minlength="4" class="w-full rounded-lg border px-4 py-2.5 text-sm focus:border-pa-orange focus:outline-none" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Confirmar contraseña</label>
          <input type="password" id="confirmPassword" required class="w-full rounded-lg border px-4 py-2.5 text-sm focus:border-pa-orange focus:outline-none" />
        </div>
        <div id="msg" class="hidden rounded-lg p-3 text-sm"></div>
        <button type="submit" class="w-full rounded-lg bg-pa-orange px-4 py-2.5 text-sm font-semibold text-white">
          Cambiar Contraseña
        </button>
      </form>

      <div class="mt-4 text-center">
        <a href="/login" class="text-sm text-pa-orange hover:underline">Volver al login</a>
      </div>
    </div>
  </div>

  <script define:vars={{ token }}>
    const form = document.getElementById('resetForm');
    const msg = document.getElementById('msg');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.classList.add('hidden');

      const newPassword = document.getElementById('newPassword').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (newPassword !== confirmPassword) {
        msg.textContent = 'Las contraseñas no coinciden';
        msg.className = 'rounded-lg bg-red-50 p-3 text-sm text-red-600';
        msg.classList.remove('hidden');
        return;
      }

      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, newPassword }),
      });
      const data = await res.json();

      if (res.ok) {
        msg.textContent = 'Contraseña actualizada. Redirigiendo al login...';
        msg.className = 'rounded-lg bg-green-50 p-3 text-sm text-green-700';
        msg.classList.remove('hidden');
        setTimeout(() => window.location.href = '/login', 2000);
      } else {
        msg.textContent = data.error;
        msg.className = 'rounded-lg bg-red-50 p-3 text-sm text-red-600';
        msg.classList.remove('hidden');
      }
    });
  </script>
</Layout>
