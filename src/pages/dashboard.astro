---
import AppLayout from '../layouts/AppLayout.astro';
import DashboardCharts from '../components/DashboardCharts';
import { db } from '../lib/db';
import { config } from '../lib/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
const companyName = db.select().from(config).where(eq(config.key, 'company_name')).get()?.value ?? 'Petro Alianza';
---

<AppLayout title="Dashboard">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500">Bienvenido, {user.username} — {companyName}</p>
  </div>

  <DashboardCharts client:load />
</AppLayout>
