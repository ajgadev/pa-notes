---
import AppLayout from '../layouts/AppLayout.astro';
import { db } from '../lib/db';
import { profiles, users } from '../lib/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
const profile = db.select().from(profiles).where(eq(profiles.userId, user.userId)).get();
const userRow = db.select({ email: users.email }).from(users).where(eq(users.id, user.userId)).get();
---

<AppLayout title="Mi Perfil">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Mi Perfil</h1>
  </div>

  <div class="max-w-lg space-y-6">
    <div class="rounded-xl border bg-white p-5 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-pa-orange">Datos</h2>
      <div class="mb-4 grid grid-cols-2 gap-3 text-sm">
        <dt class="text-gray-500">Usuario</dt>
        <dd class="font-medium">{user.username}</dd>
        <dt class="text-gray-500">Rol</dt>
        <dd><span class="rounded-full bg-pa-orange/20 px-2 py-0.5 text-xs text-pa-orange">{user.role}</span></dd>
      </div>
      <form id="profileForm" class="space-y-4">
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Nombre</label>
          <input type="text" id="profileNombre" value={profile?.nombre || ''} class="w-full rounded-md border px-3 py-2 text-sm focus:border-pa-orange focus:outline-none" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Apellido</label>
          <input type="text" id="profileApellido" value={profile?.apellido || ''} class="w-full rounded-md border px-3 py-2 text-sm focus:border-pa-orange focus:outline-none" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">C.I.</label>
          <input type="text" id="profileCi" value={profile?.ci || ''} class="w-full rounded-md border px-3 py-2 text-sm focus:border-pa-orange focus:outline-none" />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Email</label>
          <input type="email" id="profileEmail" value={userRow?.email || ''} class="w-full rounded-md border px-3 py-2 text-sm focus:border-pa-orange focus:outline-none" placeholder="correo@ejemplo.com" />
        </div>
        <div id="profileMsg" class="hidden rounded-lg p-3 text-sm"></div>
        <button type="submit" class="rounded-lg bg-pa-orange px-4 py-2 text-sm font-semibold text-white">
          Guardar Datos
        </button>
      </form>
    </div>

    <div class="rounded-xl border bg-white p-5 shadow-sm">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-pa-orange">Cambiar Contraseña</h2>
      <form id="passwordForm" class="space-y-4">
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Contraseña actual</label>
          <div class="relative">
            <input type="password" id="currentPassword" required class="w-full rounded-md border px-3 py-2 pr-10 text-sm focus:border-pa-orange focus:outline-none" />
            <button type="button" class="pw-toggle absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-400 hover:text-gray-600" tabindex="-1"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button>
          </div>
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Nueva contraseña</label>
          <div class="relative">
            <input type="password" id="newPassword" required minlength="8" class="w-full rounded-md border px-3 py-2 pr-10 text-sm focus:border-pa-orange focus:outline-none" />
            <button type="button" class="pw-toggle absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-400 hover:text-gray-600" tabindex="-1"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button>
          </div>
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-gray-600">Confirmar nueva contraseña</label>
          <div class="relative">
            <input type="password" id="confirmPassword" required class="w-full rounded-md border px-3 py-2 pr-10 text-sm focus:border-pa-orange focus:outline-none" />
            <button type="button" class="pw-toggle absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-400 hover:text-gray-600" tabindex="-1"><svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button>
          </div>
        </div>
        <div id="passwordMsg" class="hidden rounded-lg p-3 text-sm"></div>
        <button type="submit" class="rounded-lg bg-pa-orange px-4 py-2 text-sm font-semibold text-white">
          Cambiar Contraseña
        </button>
      </form>
    </div>
  </div>

  <script>
    // Profile form
    const profileForm = document.getElementById('profileForm') as HTMLFormElement;
    const profileMsg = document.getElementById('profileMsg') as HTMLDivElement;

    profileForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      profileMsg.classList.add('hidden');

      const nombre = (document.getElementById('profileNombre') as HTMLInputElement).value;
      const apellido = (document.getElementById('profileApellido') as HTMLInputElement).value;
      const ci = (document.getElementById('profileCi') as HTMLInputElement).value;
      const email = (document.getElementById('profileEmail') as HTMLInputElement).value;

      const res = await fetch('/api/perfil', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, apellido, ci, email }),
      });

      if (res.ok) {
        profileMsg.textContent = 'Datos actualizados correctamente';
        profileMsg.className = 'rounded-lg bg-green-50 p-3 text-sm text-green-700';
        setTimeout(() => profileMsg.classList.add('hidden'), 3000);
      } else {
        profileMsg.textContent = 'Error al guardar';
        profileMsg.className = 'rounded-lg bg-red-50 p-3 text-sm text-red-600';
      }
      profileMsg.classList.remove('hidden');
    });

    // Password form
    const form = document.getElementById('passwordForm') as HTMLFormElement;
    const msg = document.getElementById('passwordMsg') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.classList.add('hidden');

      const currentPassword = (document.getElementById('currentPassword') as HTMLInputElement).value;
      const newPassword = (document.getElementById('newPassword') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

      if (newPassword !== confirmPassword) {
        msg.textContent = 'Las contraseñas no coinciden';
        msg.className = 'rounded-lg bg-red-50 p-3 text-sm text-red-600';
        msg.classList.remove('hidden');
        return;
      }

      const res = await fetch('/api/auth/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword, newPassword }),
      });
      const data = await res.json();

      if (res.ok) {
        msg.textContent = 'Contraseña actualizada correctamente';
        msg.className = 'rounded-lg bg-green-50 p-3 text-sm text-green-700';
        form.reset();
        setTimeout(() => msg.classList.add('hidden'), 3000);
      } else {
        msg.textContent = data.error;
        msg.className = 'rounded-lg bg-red-50 p-3 text-sm text-red-600';
      }
      msg.classList.remove('hidden');
    });

    // Password eye toggles
    const eyeOpen = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
    const eyeClosed = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
    document.querySelectorAll('.pw-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const input = btn.parentElement!.querySelector('input') as HTMLInputElement;
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        btn.querySelector('svg')!.innerHTML = isHidden ? eyeClosed : eyeOpen;
      });
    });
  </script>
</AppLayout>
