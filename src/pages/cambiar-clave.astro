---
import Layout from '../layouts/Layout.astro';
import ChangePasswordForm from '../components/ChangePasswordForm';
import { verifyToken } from '../lib/auth';

const cookie = Astro.cookies.get('token');
const user = cookie ? verifyToken(cookie.value) : null;
if (!user) return Astro.redirect('/login');
---

<Layout title="Cambiar Contraseña">
  <div class="flex min-h-screen items-center justify-center bg-pa-dark">
    <div class="w-full max-w-md rounded-xl bg-white p-8 shadow-xl">
      <div class="mb-6 text-center">
        <h1 class="text-2xl font-bold">
          <span class="text-black">Petro</span><span class="text-pa-orange">Alianza</span>
        </h1>
        <p class="mt-2 text-sm text-gray-500">Debe cambiar su contraseña para continuar</p>
      </div>

      <ChangePasswordForm
        client:load
        endpoint="/api/auth/force-change-password"
        successRedirect="/dashboard"
      />
    </div>
  </div>
</Layout>
