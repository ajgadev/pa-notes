---
import '../styles/global.css';
import { db } from '../lib/db';
import { profiles } from '../lib/schema';
import { eq } from 'drizzle-orm';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';
const currentPath = Astro.url.pathname;
const profile = db.select().from(profiles).where(eq(profiles.userId, user.userId)).get();
const displayName = [profile?.nombre, profile?.apellido].filter(Boolean).join(' ') || user.username;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | PetroAlianza</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <!-- Topbar -->
    <header class="fixed top-0 right-0 left-0 z-50 flex h-14 items-center justify-between bg-pa-dark px-6">
      <a href="/dashboard" class="text-xl font-bold">
        <span class="text-white">Petro</span><span class="text-pa-orange">Alianza</span>
      </a>
      <div class="flex items-center gap-4">
        <span class="text-sm text-gray-300">{displayName}</span>
        <span class="rounded-full bg-pa-orange/20 px-2 py-0.5 text-xs text-pa-orange">{user?.role}</span>
        <button
          id="logoutBtn"
          class="rounded px-3 py-1 text-sm text-gray-300 transition hover:bg-white/10 hover:text-white"
        >
          Salir
        </button>
      </div>
    </header>

    <div class="flex pt-14">
      <!-- Sidebar -->
      <aside class="fixed top-14 bottom-0 left-0 w-56 overflow-y-auto bg-pa-dark/95 p-4">
        <nav class="space-y-1">
          {[
            { href: '/dashboard', label: 'Dashboard', icon: '◉' },
            { href: '/notas', label: 'Notas', icon: '📋' },
            { href: '/notas/nueva', label: 'Nueva Nota', icon: '➕' },
            { href: '/perfil', label: 'Mi Perfil', icon: '👤' },
          ].map(({ href, label, icon }) => (
            <a
              href={href}
              class:list={[
                'flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition',
                currentPath === href
                  ? 'bg-pa-orange/20 font-medium text-pa-orange'
                  : 'text-gray-300 hover:bg-white/5 hover:text-white',
              ]}
            >
              <span>{icon}</span>
              <span>{label}</span>
            </a>
          ))}

          {isAdmin && (
            <>
              <div class="my-3 border-t border-white/10" />
              <p class="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Admin</p>
              {[
                { href: '/admin/usuarios', label: 'Usuarios' },
                { href: '/admin/departamentos', label: 'Departamentos' },
                { href: '/admin/vehiculos', label: 'Vehículos' },
                { href: '/admin/personal', label: 'Personal' },
                { href: '/admin/configuracion', label: 'Configuración' },
              ].map(({ href, label }) => (
                <a
                  href={href}
                  class:list={[
                    'flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition',
                    currentPath === href
                      ? 'bg-pa-orange/20 font-medium text-pa-orange'
                      : 'text-gray-300 hover:bg-white/5 hover:text-white',
                  ]}
                >
                  <span>{label}</span>
                </a>
              ))}
            </>
          )}
        </nav>
      </aside>

      <!-- Main content -->
      <main class="ml-56 min-h-[calc(100vh-3.5rem)] flex-1 p-6">
        <slot />
      </main>
    </div>

    <script>
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
