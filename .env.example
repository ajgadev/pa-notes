# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_segura_aleatoria_minimo_64_chars

# Duración de sesión JWT
JWT_EXPIRES_IN=8h

# Ruta de la base de datos SQLite
DATABASE_URL=./data/petroalianza.db

# Puerto del servidor
PORT=4321

# Entorno (development | production)
NODE_ENV=production

# SMTP (fallback si no está configurado en Admin > Configuración)
# Resend: host=smtp.resend.com, port=465, user=resend, pass=tu_api_key
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=PetroAlianza <onboarding@resend.dev>
SMTP_ENABLED=0
